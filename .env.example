# Firebase Configuration Template
# Sao chép file này thành .env và điền các khóa thực tế của bạn
# Xem hướng dẫn lấy khóa tại: https://console.firebase.google.com/project/anki-mcq-export-app/settings/general

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=anki-mcq-export-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=anki-mcq-export-app
VITE_FIREBASE_STORAGE_BUCKET=anki-mcq-export-app.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Khóa quan trọng nhất để Google Analytics kết nối và gửi dữ liệu về đúng luồng (Measurement ID)
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here
